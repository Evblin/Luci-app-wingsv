config wingsv 'main'
	option enabled '0'
	option backend 'xray'
	option auto_start '0'
	option log_lines '120'

config xray 'xray'
	option enabled '1'
	option profile_title 'Default'
	option raw_link ''
	option allow_lan '0'
	option allow_insecure '0'
	option ipv6 '1'
	option sniffing_enabled '1'
	option proxy_quic_enabled '0'
	option local_proxy_enabled '1'
	option local_proxy_port '10808'
	option local_proxy_auth_enabled '0'
	option local_proxy_username ''
	option local_proxy_password ''
	option remote_dns 'https://common.dot.dns.yandex.net/dns-query'
	option direct_dns 'https://common.dot.dns.yandex.net/dns-query'
	option transport_mode 'direct'

config vkturn 'vkturn'
	option enabled '0'
	option runtime_mode 'service'
	option endpoint ''
	option local_endpoint '127.0.0.1:9000'
	option threads '24'
	option creds_group_size '12'
	option use_udp '1'
	option no_obfuscation '0'
	option manual_captcha '0'
	option captcha_auto_solver 'v2'
	option session_mode 'mainline'
	option turn_host ''
	option turn_port ''
	option link ''

config wireguard 'wireguard'
	option enabled '0'
	option private_key ''
	option addresses ''
	option dns '1.1.1.1, 1.0.0.1'
	option mtu '1280'
	option public_key ''
	option preshared_key ''
	option allowed_ips '0.0.0.0/0, ::/0'
	option endpoint ''
	option quick_config ''

config amneziawg 'amneziawg'
	option enabled '0'
	option quick_config ''

config byedpi 'byedpi'
	option enabled '0'
	option auto_start_with_xray '0'
	option use_command_settings '1'
	option proxy_ip '127.0.0.1'
	option proxy_port '1080'
	option proxy_auth_enabled '0'
	option proxy_username ''
	option proxy_password ''
	option max_connections '512'
	option buffer_size '16384'
	option no_domain '0'
	option tcp_fast_open '0'
	option hosts_mode 'disable'
	option hosts_blacklist ''
	option hosts_whitelist ''
	option default_ttl '0'
	option desync_method 'oob'
	option split_position '1'
	option split_at_host '0'
	option drop_sack '0'
	option fake_ttl '8'
	option fake_offset '0'
	option fake_sni 'www.iana.org'
	option oob_data 'a'
	option desync_http '1'
	option desync_https '1'
	option desync_udp '1'
	option host_mixed_case '0'
	option domain_mixed_case '0'
	option host_remove_spaces '0'
	option tlsrec_enabled '1'
	option tlsrec_position '1'
	option tlsrec_at_sni '1'
	option udp_fake_count '1'
	option cmd_args '-o1 -d1 -a1 -At,r,s -s1 -d1 -s5+s -s10+s -s15+s -s20+s -r1+s -S -a1 -As -s1 -d1 -s5+s -s10+s -s15+s -s20+s -S -a1'
